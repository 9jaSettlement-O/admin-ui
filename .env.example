# API base URL for backend (optional when using mock)
VITE_APP_API_URL=

# Base path for production (must match deployment URL subpath).
# - Omit or leave empty: defaults to /admin-ui/ for production.
# - GitHub Pages (project site): set to /<repo-name>/ (workflow sets this automatically).
# - AWS/CloudFront at domain root: set to /
# VITE_BASE_PATH=/admin-ui/

# Use mock services (login, data) - no API required. Default: true in DEV when API URL not set.
# VITE_USE_MOCK_SERVICES=true
